rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isSignedIn() { return request.auth != null; }
    function role(r)      { return isSignedIn() && request.auth.token.roles[r] == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin()    { return role('superadmin') || role('university_admin'); }

    // Universities — public read, admin write.
    match /universities/{uniId} {
      allow read: if true;
      allow write: if isAdmin();

      match /schools/{schoolId} {
        allow read: if true;
        allow write: if isAdmin() || role('rep');

        match /departments/{departmentId} {
          allow read: if true;
          allow write: if isAdmin() || role('rep');
        }
      }

      match /classes/{classId} {
        allow read: if true;
        allow write: if isAdmin();

        match /graduates/{gradId} {
          allow read: if resource.data.status in ['approved', 'sealed']
                      || (isSignedIn() && resource.data.uid == request.auth.uid)
                      || role('rep') || isAdmin();

          // Create / delete: rep or admin only.
          allow create: if role('rep') || isAdmin();
          allow delete: if isAdmin();

          // Owner updates: status field locked, sealed docs immutable.
          allow update: if (
            isOwner(resource.data.uid)
            && resource.data.status != 'sealed'
            && request.resource.data.status == resource.data.status
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.universityId == resource.data.universityId
            && request.resource.data.classId == resource.data.classId
          ) || role('rep') || isAdmin();

          match /memories/{memoryId} {
            allow read: if true;
            allow write: if isSignedIn() &&
              (get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid
               || isAdmin());
          }

          // Goodwills: public-facing submissions go through the Next API route
          // + submitGoodwill callable (admin SDK bypasses rules). Direct client
          // writes are blocked to stop drive-by spam.
          match /goodwills/{goodwillId} {
            allow read: if resource.data.approved == true || isAdmin()
              || get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid;
            allow create: if false;
            allow update, delete: if isAdmin()
              || get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid;
          }

          // Sealing snapshot — written by sealClass callable; read by admins.
          match /archive/{archiveId} {
            allow read: if isAdmin();
            allow write: if false;
          }
        }
      }
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid) || role('superadmin');
    }

    // Onboarding requests: write only via server route (admin SDK).
    match /onboardingRequests/{id} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    // Contact inbox: write only via server route (admin SDK).
    match /contacts/{id} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    // Audit log: server-only writes.
    match /audit/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
