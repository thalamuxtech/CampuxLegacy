rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isSignedIn() { return request.auth != null; }
    function role(r)      { return isSignedIn() && request.auth.token.roles[r] == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin()    { return role('superadmin') || role('university_admin'); }

    // Universities — public read, admin write
    match /universities/{uniId} {
      allow read: if true;
      allow write: if isAdmin();

      match /schools/{schoolId} {
        allow read: if true;
        allow write: if isAdmin() || role('rep');

        match /departments/{departmentId} {
          allow read: if true;
          allow write: if isAdmin() || role('rep');
        }
      }

      match /classes/{classId} {
        allow read: if true;
        allow write: if isAdmin();

        match /graduates/{gradId} {
          allow read: if resource.data.status in ['approved', 'sealed']
                      || (isSignedIn() && resource.data.uid == request.auth.uid)
                      || role('rep') || isAdmin();
          allow update: if (isOwner(resource.data.uid) && resource.data.status != 'sealed')
                        || role('rep') || isAdmin();
          allow create: if role('rep') || isAdmin();
          allow delete: if isAdmin();

          match /memories/{memoryId} {
            allow read: if true;
            allow write: if isSignedIn() &&
              (get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid
               || isAdmin());
          }

          match /goodwills/{goodwillId} {
            allow read: if resource.data.approved == true || isAdmin()
              || get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid;
            allow create: if true; // anyone can leave a goodwill (server moderates)
            allow update, delete: if isAdmin()
              || get(/databases/$(db)/documents/universities/$(uniId)/classes/$(classId)/graduates/$(gradId)).data.uid == request.auth.uid;
          }
        }
      }
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid) || role('superadmin');
    }

    match /onboardingRequests/{id} {
      allow create: if true;
      allow read, update, delete: if role('superadmin');
    }

    match /audit/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // only server (admin SDK) writes
    }
  }
}
