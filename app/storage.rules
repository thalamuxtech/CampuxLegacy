rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function role(r) { return isSignedIn() && request.auth.token.roles[r] == true; }
    function ownsGraduate(gid) {
      return isSignedIn()
        && request.auth.token.graduateIds != null
        && request.auth.token.graduateIds[gid] == true;
    }
    function isAdmin() { return role('superadmin') || role('university_admin'); }

    // Public read for portrait variants (written by Cloud Function only)
    match /graduates/{graduateId}/portrait/variants/{file=**} {
      allow read: if true;
      allow write: if false;
    }

    // Originals: only the linked graduate owner (or admin) may upload.
    match /graduates/{graduateId}/portrait/original {
      allow read: if false;
      allow write: if (ownsGraduate(graduateId) || isAdmin())
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Showcase video: same restriction as portrait.
    match /graduates/{graduateId}/showcase/{file=**} {
      allow read: if false;
      allow write: if (ownsGraduate(graduateId) || isAdmin())
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /universities/{uniId}/branding/{file=**} {
      allow read: if true;
      allow write: if role('university_admin') || role('superadmin');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
